% -------- JR各社の規則等の条文のスタイル定義

% - colors/jr.sty
% - headers/jr.sty
% が必須

% ---- 本州3社

% n条
\newcommand{\ArticleJRHonshu}[1]{%
  \qquad \\[-6pt] %
  {\JREast}{\JRCentral}{\JRWest}\,\textgt{第\textsf{#1}条}%
  \\[-18pt] %
}

% n条 + 内容
\newcommand{\ArticleContentJRHonshu}[2]{%
  \qquad \\[-6pt] %
  （#2） \\[3pt] %
  {\JREast}{\JRCentral}{\JRWest}\,\textgt{第\textsf{#1}条}%
  \\[-18pt] %
}

% n条のm
\newcommand{\ArticleSubJRHonshu}[2]{%
  \qquad \\[-6pt] %
  {\JREast}{\JRCentral}{\JRWest}\,\textgt{第\textsf{#1}条の\textsf{#2}}%
  \\[-18pt] %
}

% n条のm + 内容
\newcommand{\ArticleSubContentJRHonshu}[3]{%
  \qquad \\[-6pt] %
  （#3） \\[3pt] %
  {\JREast}{\JRCentral}{\JRWest}\,\textgt{第\textsf{#1}条の\textsf{#2}}%
  \\[-18pt] %
}

