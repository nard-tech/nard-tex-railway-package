% -------- JR各社の規則等の条文のスタイル定義

\usepackage{./colors/jr}
\usepackage{./box}

% ---- 内部で使用するコマンド

\newcommand{\ArticleNumber}[1]{\textgt{第\textsf{#1}条}}
\newcommand{\ArticleNumberSub}[2]{\textgt{第\textsf{#1}条の\textsf{#2}}}

% n条
\newcommand{\Article}[2]{%
  #1\,\ArticleNumber{#2}% ロゴ、条文番号
}

% n条のm
\newcommand{\ArticleSub}[3]{%
  #1\,\ArticleNumberSub{#2}{#3}% ロゴ、条文番号、枝番
}

% n条 + 内容
\newcommand{\ArticleContent}[3]{%
  （{#3}）\\[3pt]% 内容
  #1\,\ArticleNumber{#2}% ロゴ、条文番号
}

% n条のm + 内容
\newcommand{\ArticleContentSub}[4]{%
  （{#4}）\\[3pt]% 内容
  #1\,\ArticleNumber{#2}{#3}% ロゴ、条文番号、枝番
}

% ---- 本州3社

% n条
\newcommand{\ArticleJRHonshu}[1]{%
  \Article{%
    \JREast\JRCentral\JRWest}{%
    #1}%
}

% n条のm
\newcommand{\ArticleSubJRHonshu}[2]{%
  \ArticleSub{%
    \JREast\JRCentral\JRWest}{%
    #1}{%
    #2}%
}

% n条 + 内容
\newcommand{\ArticleContentJRHonshu}[2]{%
  \ArticleContent{%
    \JREast\JRCentral\JRWest}{%
    #1}{% 条文番号
    #2}% 内容
}

% n条のm + 内容
\newcommand{\ArticleSubContentJRHonshu}[3]{%
  \ArticleContentSub{%
    \JREast\JRCentral\JRWest}{%
    #1}{% 条文番号
    #2}{% 枝番
    #3}% 内容
}

